generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEDICAL_AFFAIRS
  MSL
  CLINICAL_DEVELOPMENT
  COMPLIANCE_REVIEWER
  SYSTEM
}

enum ProtocolStatus {
  QUEUED
  PARSING
  EXTRACTING
  RETRIEVING_EVIDENCE
  RANKING
  INDEXING
  READY_FOR_REVIEW
  COMPLETED
  FAILED
  ARCHIVED
}

enum ProtocolDocumentType {
  PROTOCOL
  AMENDMENT
  SAP
  CSR
  PUBLICATION
  OTHER
}

enum ProcessingRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  COMPLETED_WITH_WARNINGS
  FAILED
  CANCELED
}

enum ProcessingStageKey {
  PARSED
  BRIEF
  QUERIES
  EVIDENCE
  KOLS
  RANKED
  MOSS
  REVIEW
  EXPORT
}

enum ProcessingStageStatus {
  PENDING
  ACTIVE
  DONE
  WARN
  ERROR
  SKIPPED
}

enum BriefSectionStatus {
  DRAFT
  REVIEW
  VALIDATED
  REJECTED
}

enum QueryGroupStatus {
  DRAFT
  APPROVED
  EDITED
  REGENERATING
  ARCHIVED
}

enum EvidenceSourceType {
  PUBLICATION
  TRIAL_REGISTRY
  GUIDELINE
  CONGRESS
  TRANSPARENCY_RECORD
  INSTITUTION_PROFILE
  EXPERT_BIO
  SITE_RECORD
  OTHER
}

enum EvidenceStrength {
  WEAK
  MODERATE
  STRONG
}

enum ExpertStatus {
  DRAFT
  NORMALIZED
  VALIDATED
  REVIEW
  ARCHIVED
}

enum CandidateStatus {
  EXTRACTED
  REVIEW
  VALIDATED
  REJECTED
  SHORTLISTED
}

enum RankingRunStatus {
  DRAFT
  RUNNING
  COMPLETE
  FAILED
  SUPERSEDED
}

enum ComplianceSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplianceFlagStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

enum ComplianceRuleResult {
  PASS
  WARN
  FAIL
  NOT_APPLICABLE
}

enum MossAssetType {
  PROTOCOL_CHUNK
  EVIDENCE_CHUNK
  EXPERT_PROFILE
  RANKING_METADATA
  SOURCE_CITATION
  BRIEF
}

enum MossIndexStatus {
  QUEUED
  EMBEDDED
  RETRYING
  FAILED
  SKIPPED
}

enum BriefStatus {
  DRAFT
  GENERATED
  REVIEWED
  APPROVED
  ARCHIVED
}

enum ConversationChannel {
  VOICE
  CHAT
  SYSTEM
}

enum MessageRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM
}

enum ExportFormat {
  PDF
  CSV
  JSON
  DOCX
}

enum ExportStatus {
  QUEUED
  RUNNING
  READY
  FAILED
  EXPIRED
}

enum CitationUsage {
  RANKING_RATIONALE
  BRIEF_CLAIM
  ANSWER_SUPPORT
  COMPLIANCE_REVIEW
  PROTOCOL_EXTRACTION
}

enum ActivityType {
  CONGRESS_PRESENTATION
  GUIDELINE_AUTHORSHIP
  SOCIETY_ROLE
  PUBLICATION_AUTHORSHIP
  TRIAL_INVESTIGATOR
  SITE_LEADERSHIP
  ADVISORY_BOARD
  OTHER
}

enum PaymentNature {
  CONSULTING
  HONORARIA
  RESEARCH
  FOOD_TRAVEL
  EDUCATION
  ROYALTY
  OTHER
  UNKNOWN
}

model Organization {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  users           User[]
  protocols       Protocol[]
  institutions    Institution[]
  complianceRules ComplianceRule[]
  auditEvents     AuditEvent[]

  @@map("organizations")
}

model User {
  id                      String                 @id @default(cuid())
  email                   String                 @unique
  name                    String?
  role                    UserRole               @default(MEDICAL_AFFAIRS)
  organizationId          String?
  organization            Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  uploadedProtocols       Protocol[]             @relation("ProtocolUploader")
  uploadedDocuments       ProtocolDocument[]     @relation("ProtocolDocumentUploader")
  startedRuns             ProcessingRun[]        @relation("ProcessingRunStarter")
  reviewedBriefSections   ProtocolBriefSection[] @relation("ProtocolBriefReviewer")
  createdQueryGroups      SearchQueryGroup[]     @relation("SearchQueryGroupCreator")
  reviewedComplianceFlags ComplianceFlag[]       @relation("ComplianceFlagReviewer")
  createdBriefs           MslBrief[]             @relation("MslBriefCreator")
  conversationSessions    ConversationSession[]
  exportArtifacts         ExportArtifact[]       @relation("ExportArtifactCreator")
  auditEvents             AuditEvent[]
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  @@index([organizationId])
  @@map("users")
}

model Protocol {
  id                  String                    @id @default(cuid())
  organizationId      String?
  organization        Organization?             @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  protocolCode        String
  nctId               String?
  title               String
  sponsor             String?
  phase               String?
  indication          String?
  intervention        String?
  patientPopulation   String?
  enrollmentTarget    Int?
  enrollmentDisplay   String?
  geographies         String[]                  @default([])
  therapeuticAreas    String[]                  @default([])
  relevantSpecialties String[]                  @default([])
  status              ProtocolStatus            @default(QUEUED)
  sourceUrl           String?
  uploadedById        String?
  uploadedBy          User?                     @relation("ProtocolUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  documents           ProtocolDocument[]
  chunks              ProtocolChunk[]
  briefSections       ProtocolBriefSection[]
  queryGroups         SearchQueryGroup[]
  runs                ProcessingRun[]
  evidenceSnippets    EvidenceSnippet[]
  citations           Citation[]
  candidates          ProtocolExpertCandidate[]
  rankingRuns         RankingRun[]
  complianceChecks    ComplianceCheck[]
  complianceFlags     ComplianceFlag[]
  mossAssets          MossIndexAsset[]
  mossItems           MossIndexItem[]
  briefs              MslBrief[]
  conversations       ConversationSession[]
  exports             ExportArtifact[]
  auditEvents         AuditEvent[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@unique([organizationId, protocolCode])
  @@index([status])
  @@index([nctId])
  @@map("protocols")
}

model ProtocolDocument {
  id            String               @id @default(cuid())
  protocolId    String
  protocol      Protocol             @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  type          ProtocolDocumentType @default(PROTOCOL)
  fileName      String
  fileSizeBytes BigInt?
  mimeType      String?
  storageUrl    String?
  checksum      String?
  sourceUrl     String?
  uploadedById  String?
  uploadedBy    User?                @relation("ProtocolDocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  parsedAt      DateTime?
  chunks        ProtocolChunk[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([protocolId])
  @@map("protocol_documents")
}

model ProtocolChunk {
  id             String                 @id @default(cuid())
  protocolId     String
  protocol       Protocol               @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  documentId     String?
  document       ProtocolDocument?      @relation(fields: [documentId], references: [id], onDelete: SetNull)
  chunkIndex     Int
  heading        String?
  pageStart      Int?
  pageEnd        Int?
  tokenCount     Int?
  text           String
  extractionJson Json?
  briefSections  ProtocolBriefSection[]
  citations      Citation[]
  mossItems      MossIndexItem[]
  createdAt      DateTime               @default(now())

  @@unique([protocolId, chunkIndex])
  @@index([documentId])
  @@map("protocol_chunks")
}

model ProtocolBriefSection {
  id            String                  @id @default(cuid())
  protocolId    String
  protocol      Protocol                @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  runId         String?
  run           ProcessingRun?          @relation(fields: [runId], references: [id], onDelete: SetNull)
  sectionKey    String
  sectionLabel  String
  value         String
  confidence    Float?
  sourceChunkId String?
  sourceChunk   ProtocolChunk?          @relation(fields: [sourceChunkId], references: [id], onDelete: SetNull)
  status        BriefSectionStatus      @default(DRAFT)
  reviewerId    String?
  reviewer      User?                   @relation("ProtocolBriefReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  reviewedAt    DateTime?
  citations     ProtocolBriefCitation[]
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@unique([protocolId, sectionKey])
  @@index([runId])
  @@index([sourceChunkId])
  @@map("protocol_brief_sections")
}

model ProcessingRun {
  id               String                    @id @default(cuid())
  runKey           String                    @unique
  protocolId       String
  protocol         Protocol                  @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  startedById      String?
  startedBy        User?                     @relation("ProcessingRunStarter", fields: [startedById], references: [id], onDelete: SetNull)
  status           ProcessingRunStatus       @default(QUEUED)
  stageLabel       String?
  startedAt        DateTime                  @default(now())
  completedAt      DateTime?
  durationMs       Int?
  summary          Json?
  errorMessage     String?
  stages           ProcessingStage[]
  briefSections    ProtocolBriefSection[]
  queryGroups      SearchQueryGroup[]
  evidenceSnippets EvidenceSnippet[]
  candidates       ProtocolExpertCandidate[]
  rankingRuns      RankingRun[]
  complianceChecks ComplianceCheck[]
  mossAssets       MossIndexAsset[]
  mossItems        MossIndexItem[]
  briefs           MslBrief[]
  exports          ExportArtifact[]
  auditEvents      AuditEvent[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([protocolId])
  @@index([status])
  @@map("processing_runs")
}

model ProcessingStage {
  id          String                @id @default(cuid())
  runId       String
  run         ProcessingRun         @relation(fields: [runId], references: [id], onDelete: Cascade)
  key         ProcessingStageKey
  label       String
  status      ProcessingStageStatus @default(PENDING)
  detail      String?
  order       Int
  metrics     Json?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  @@unique([runId, key])
  @@index([status])
  @@map("processing_stages")
}

model SearchQueryGroup {
  id            String           @id @default(cuid())
  protocolId    String
  protocol      Protocol         @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  runId         String?
  run           ProcessingRun?   @relation(fields: [runId], references: [id], onDelete: SetNull)
  name          String
  status        QueryGroupStatus @default(DRAFT)
  sourceTargets String[]         @default([])
  resultCount   Int?
  generatedFrom Json?
  createdById   String?
  createdBy     User?            @relation("SearchQueryGroupCreator", fields: [createdById], references: [id], onDelete: SetNull)
  queries       SearchQuery[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([protocolId])
  @@index([runId])
  @@map("search_query_groups")
}

model SearchQuery {
  id            String           @id @default(cuid())
  queryGroupId  String
  queryGroup    SearchQueryGroup @relation(fields: [queryGroupId], references: [id], onDelete: Cascade)
  text          String
  sourceTargets String[]         @default([])
  resultCount   Int?
  approvedAt    DateTime?
  executedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([queryGroupId])
  @@map("search_queries")
}

model EvidenceSource {
  id                  String               @id @default(cuid())
  type                EvidenceSourceType
  title               String
  host                String?
  sourceUrl           String?
  externalId          String?
  publishedAt         DateTime?
  accessedAt          DateTime?
  metadata            Json?
  snippets            EvidenceSnippet[]
  citations           Citation[]
  publication         Publication?
  clinicalTrial       ClinicalTrial?
  guidelineDocument   GuidelineDocument?
  expertActivities    ExpertActivity[]
  transparencyRecords TransparencyRecord[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([type, externalId])
  @@index([type])
  @@map("evidence_sources")
}

model EvidenceSnippet {
  id              String            @id @default(cuid())
  sourceId        String
  source          EvidenceSource    @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  protocolId      String?
  protocol        Protocol?         @relation(fields: [protocolId], references: [id], onDelete: SetNull)
  runId           String?
  run             ProcessingRun?    @relation(fields: [runId], references: [id], onDelete: SetNull)
  text            String
  score           Float?
  strength        EvidenceStrength?
  page            String?
  metadata        Json?
  expertLinks     ExpertEvidence[]
  citations       Citation[]
  scoreComponents ScoreComponent[]
  mossItems       MossIndexItem[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([sourceId])
  @@index([protocolId])
  @@index([runId])
  @@map("evidence_snippets")
}

model Citation {
  id                    String                        @id @default(cuid())
  protocolId            String?
  protocol              Protocol?                     @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  evidenceSourceId      String?
  evidenceSource        EvidenceSource?               @relation(fields: [evidenceSourceId], references: [id], onDelete: SetNull)
  evidenceSnippetId     String?
  evidenceSnippet       EvidenceSnippet?              @relation(fields: [evidenceSnippetId], references: [id], onDelete: SetNull)
  protocolChunkId       String?
  protocolChunk         ProtocolChunk?                @relation(fields: [protocolChunkId], references: [id], onDelete: SetNull)
  title                 String
  url                   String?
  label                 String?
  usage                 CitationUsage
  quotedText            String?
  accessedAt            DateTime?
  candidateLinks        CandidateCitation[]
  briefLinks            BriefCitation[]
  messageLinks          ConversationMessageCitation[]
  protocolBriefSections ProtocolBriefCitation[]
  mossItems             MossIndexItem[]
  createdAt             DateTime                      @default(now())

  @@index([protocolId])
  @@index([evidenceSourceId])
  @@index([evidenceSnippetId])
  @@index([usage])
  @@map("citations")
}

model Expert {
  id                   String                    @id @default(cuid())
  slug                 String                    @unique
  npi                  String?                   @unique
  name                 String
  normalizedName       String?
  credential           String?
  primarySpecialty     String?
  secondarySpecialties String[]                  @default([])
  geography            String?
  country              String?
  region               String?
  city                 String?
  profileSummary       String?
  status               ExpertStatus              @default(DRAFT)
  openPaymentsUrl      String?
  aliases              ExpertAlias[]
  affiliations         ExpertAffiliation[]
  candidates           ProtocolExpertCandidate[]
  evidenceLinks        ExpertEvidence[]
  publicationAuthors   PublicationAuthor[]
  trialRoles           TrialInvestigator[]
  activities           ExpertActivity[]
  transparencyRecords  TransparencyRecord[]
  rankingResults       ExpertRankingResult[]
  complianceFlags      ComplianceFlag[]
  briefs               MslBrief[]
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([primarySpecialty])
  @@index([country])
  @@map("experts")
}

model ExpertAlias {
  id        String   @id @default(cuid())
  expertId  String
  expert    Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  alias     String
  source    String?
  createdAt DateTime @default(now())

  @@unique([expertId, alias])
  @@map("expert_aliases")
}

model Institution {
  id             String              @id @default(cuid())
  organizationId String?
  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  slug           String              @unique
  name           String
  type           String?
  department     String?
  city           String?
  region         String?
  country        String?
  websiteUrl     String?
  metadata       Json?
  affiliations   ExpertAffiliation[]
  trialSites     TrialSite[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId])
  @@index([country])
  @@map("institutions")
}

model ExpertAffiliation {
  id            String      @id @default(cuid())
  expertId      String
  expert        Expert      @relation(fields: [expertId], references: [id], onDelete: Cascade)
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  title         String?
  department    String?
  startedAt     DateTime?
  endedAt       DateTime?
  isPrimary     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([expertId, institutionId, title])
  @@index([institutionId])
  @@map("expert_affiliations")
}

model ExpertEvidence {
  id                String          @id @default(cuid())
  expertId          String
  expert            Expert          @relation(fields: [expertId], references: [id], onDelete: Cascade)
  evidenceSnippetId String
  evidenceSnippet   EvidenceSnippet @relation(fields: [evidenceSnippetId], references: [id], onDelete: Cascade)
  relevanceNote     String?
  confidence        Float?
  createdAt         DateTime        @default(now())

  @@unique([expertId, evidenceSnippetId])
  @@index([evidenceSnippetId])
  @@map("expert_evidence")
}

model Publication {
  id               String              @id @default(cuid())
  evidenceSourceId String?             @unique
  evidenceSource   EvidenceSource?     @relation(fields: [evidenceSourceId], references: [id], onDelete: SetNull)
  title            String
  journal          String?
  abstract         String?
  doi              String?             @unique
  pmid             String?             @unique
  url              String?
  publishedAt      DateTime?
  year             Int?
  authors          PublicationAuthor[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([year])
  @@map("publications")
}

model PublicationAuthor {
  id              String      @id @default(cuid())
  publicationId   String
  publication     Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  expertId        String?
  expert          Expert?     @relation(fields: [expertId], references: [id], onDelete: SetNull)
  authorName      String
  authorOrder     Int?
  isCorresponding Boolean     @default(false)
  affiliationText String?
  createdAt       DateTime    @default(now())

  @@unique([publicationId, authorName])
  @@index([expertId])
  @@map("publication_authors")
}

model ClinicalTrial {
  id               String              @id @default(cuid())
  evidenceSourceId String?             @unique
  evidenceSource   EvidenceSource?     @relation(fields: [evidenceSourceId], references: [id], onDelete: SetNull)
  nctId            String?             @unique
  title            String
  sponsor          String?
  phase            String?
  indication       String?
  status           String?
  registryUrl      String?
  startDate        DateTime?
  completionDate   DateTime?
  sites            TrialSite[]
  investigators    TrialInvestigator[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([phase])
  @@map("clinical_trials")
}

model TrialSite {
  id               String              @id @default(cuid())
  trialId          String
  trial            ClinicalTrial       @relation(fields: [trialId], references: [id], onDelete: Cascade)
  institutionId    String?
  institution      Institution?        @relation(fields: [institutionId], references: [id], onDelete: SetNull)
  siteName         String
  city             String?
  region           String?
  country          String?
  status           String?
  enrollmentTarget Int?
  investigators    TrialInvestigator[]
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@index([trialId])
  @@index([institutionId])
  @@map("trial_sites")
}

model TrialInvestigator {
  id          String        @id @default(cuid())
  trialId     String
  trial       ClinicalTrial @relation(fields: [trialId], references: [id], onDelete: Cascade)
  trialSiteId String?
  trialSite   TrialSite?    @relation(fields: [trialSiteId], references: [id], onDelete: SetNull)
  expertId    String?
  expert      Expert?       @relation(fields: [expertId], references: [id], onDelete: SetNull)
  name        String
  role        String?
  isPrincipal Boolean       @default(false)
  countries   String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([trialId])
  @@index([expertId])
  @@map("trial_investigators")
}

model GuidelineDocument {
  id               String          @id @default(cuid())
  evidenceSourceId String?         @unique
  evidenceSource   EvidenceSource? @relation(fields: [evidenceSourceId], references: [id], onDelete: SetNull)
  title            String
  issuingBody      String?
  url              String?
  publishedAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("guideline_documents")
}

model ExpertActivity {
  id               String          @id @default(cuid())
  expertId         String
  expert           Expert          @relation(fields: [expertId], references: [id], onDelete: Cascade)
  evidenceSourceId String?
  evidenceSource   EvidenceSource? @relation(fields: [evidenceSourceId], references: [id], onDelete: SetNull)
  type             ActivityType
  title            String
  organizer        String?
  location         String?
  activityDate     DateTime?
  url              String?
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([expertId])
  @@index([type])
  @@map("expert_activities")
}

model TransparencyRecord {
  id               String          @id @default(cuid())
  expertId         String
  expert           Expert          @relation(fields: [expertId], references: [id], onDelete: Cascade)
  evidenceSourceId String?
  evidenceSource   EvidenceSource? @relation(fields: [evidenceSourceId], references: [id], onDelete: SetNull)
  programYear      Int?
  payer            String?
  nature           PaymentNature   @default(UNKNOWN)
  amount           Decimal?        @db.Decimal(12, 2)
  currency         String          @default("USD")
  sourceUrl        String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([expertId])
  @@index([programYear])
  @@map("transparency_records")
}

model ProtocolExpertCandidate {
  id               String                @id @default(cuid())
  protocolId       String
  protocol         Protocol              @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  runId            String?
  run              ProcessingRun?        @relation(fields: [runId], references: [id], onDelete: SetNull)
  expertId         String
  expert           Expert                @relation(fields: [expertId], references: [id], onDelete: Cascade)
  rank             Int?
  score            Float?
  sourcesCount     Int                   @default(0)
  flagsCount       Int                   @default(0)
  status           CandidateStatus       @default(EXTRACTED)
  rationale        String?
  reviewerNote     String?
  shortlistedAt    DateTime?
  rankingResults   ExpertRankingResult[]
  scoreComponents  ScoreComponent[]
  citations        CandidateCitation[]
  complianceChecks ComplianceCheck[]
  complianceFlags  ComplianceFlag[]
  briefs           MslBrief[]
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([protocolId, expertId])
  @@index([runId])
  @@index([status])
  @@map("protocol_expert_candidates")
}

model RankingModel {
  id          String             @id @default(cuid())
  name        String
  version     String
  description String?
  isDefault   Boolean            @default(false)
  dimensions  RankingDimension[]
  runs        RankingRun[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([name, version])
  @@map("ranking_models")
}

model RankingDimension {
  id        String       @id @default(cuid())
  modelId   String
  model     RankingModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  key       String
  label     String
  weight    Float
  order     Int
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([modelId, key])
  @@map("ranking_dimensions")
}

model RankingRun {
  id              String                @id @default(cuid())
  protocolId      String
  protocol        Protocol              @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  processingRunId String?
  processingRun   ProcessingRun?        @relation(fields: [processingRunId], references: [id], onDelete: SetNull)
  modelId         String
  model           RankingModel          @relation(fields: [modelId], references: [id], onDelete: Restrict)
  status          RankingRunStatus      @default(DRAFT)
  config          Json?
  startedAt       DateTime              @default(now())
  completedAt     DateTime?
  results         ExpertRankingResult[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([protocolId])
  @@index([processingRunId])
  @@map("ranking_runs")
}

model ExpertRankingResult {
  id           String                  @id @default(cuid())
  rankingRunId String
  rankingRun   RankingRun              @relation(fields: [rankingRunId], references: [id], onDelete: Cascade)
  candidateId  String
  candidate    ProtocolExpertCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  expertId     String
  expert       Expert                  @relation(fields: [expertId], references: [id], onDelete: Cascade)
  rank         Int
  score        Float
  rationale    String?
  components   ScoreComponent[]
  createdAt    DateTime                @default(now())

  @@unique([rankingRunId, expertId])
  @@index([candidateId])
  @@map("expert_ranking_results")
}

model ScoreComponent {
  id                String                   @id @default(cuid())
  rankingResultId   String?
  rankingResult     ExpertRankingResult?     @relation(fields: [rankingResultId], references: [id], onDelete: Cascade)
  candidateId       String?
  candidate         ProtocolExpertCandidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  evidenceSnippetId String?
  evidenceSnippet   EvidenceSnippet?         @relation(fields: [evidenceSnippetId], references: [id], onDelete: SetNull)
  dimensionKey      String
  label             String
  weight            Float
  rawScore          Float
  weightedScore     Float
  explanation       String?
  createdAt         DateTime                 @default(now())

  @@index([rankingResultId])
  @@index([candidateId])
  @@index([evidenceSnippetId])
  @@map("score_components")
}

model CandidateCitation {
  id          String                  @id @default(cuid())
  candidateId String
  candidate   ProtocolExpertCandidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  citationId  String
  citation    Citation                @relation(fields: [citationId], references: [id], onDelete: Cascade)
  note        String?
  weight      Float?
  createdAt   DateTime                @default(now())

  @@unique([candidateId, citationId])
  @@index([citationId])
  @@map("candidate_citations")
}

model ComplianceRule {
  id             String                     @id @default(cuid())
  organizationId String?
  organization   Organization?              @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  code           String
  label          String
  description    String?
  severity       ComplianceSeverity         @default(MEDIUM)
  isActive       Boolean                    @default(true)
  evaluations    ComplianceRuleEvaluation[]
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@unique([organizationId, code])
  @@index([isActive])
  @@map("compliance_rules")
}

model ComplianceCheck {
  id                    String                     @id @default(cuid())
  protocolId            String?
  protocol              Protocol?                  @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  runId                 String?
  run                   ProcessingRun?             @relation(fields: [runId], references: [id], onDelete: SetNull)
  candidateId           String?
  candidate             ProtocolExpertCandidate?   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  briefId               String?
  brief                 MslBrief?                  @relation(fields: [briefId], references: [id], onDelete: Cascade)
  conversationMessageId String?
  conversationMessage   ConversationMessage?       @relation(fields: [conversationMessageId], references: [id], onDelete: Cascade)
  checkerVersion        String?
  result                ComplianceRuleResult       @default(PASS)
  findings              Json?
  evaluations           ComplianceRuleEvaluation[]
  flags                 ComplianceFlag[]
  checkedAt             DateTime                   @default(now())
  createdAt             DateTime                   @default(now())

  @@index([protocolId])
  @@index([candidateId])
  @@index([briefId])
  @@map("compliance_checks")
}

model ComplianceRuleEvaluation {
  id        String               @id @default(cuid())
  checkId   String
  check     ComplianceCheck      @relation(fields: [checkId], references: [id], onDelete: Cascade)
  ruleId    String
  rule      ComplianceRule       @relation(fields: [ruleId], references: [id], onDelete: Restrict)
  result    ComplianceRuleResult
  detail    String?
  createdAt DateTime             @default(now())

  @@unique([checkId, ruleId])
  @@index([ruleId])
  @@map("compliance_rule_evaluations")
}

model ComplianceFlag {
  id                String                   @id @default(cuid())
  complianceCheckId String?
  complianceCheck   ComplianceCheck?         @relation(fields: [complianceCheckId], references: [id], onDelete: SetNull)
  protocolId        String?
  protocol          Protocol?                @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  candidateId       String?
  candidate         ProtocolExpertCandidate? @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  expertId          String?
  expert            Expert?                  @relation(fields: [expertId], references: [id], onDelete: SetNull)
  briefId           String?
  brief             MslBrief?                @relation(fields: [briefId], references: [id], onDelete: Cascade)
  severity          ComplianceSeverity
  type              String
  detail            String
  status            ComplianceFlagStatus     @default(OPEN)
  reviewerId        String?
  reviewer          User?                    @relation("ComplianceFlagReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  resolvedAt        DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([protocolId])
  @@index([candidateId])
  @@index([expertId])
  @@index([status])
  @@map("compliance_flags")
}

model MossIndexAsset {
  id             String          @id @default(cuid())
  protocolId     String
  protocol       Protocol        @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  runId          String?
  run            ProcessingRun?  @relation(fields: [runId], references: [id], onDelete: SetNull)
  assetType      MossAssetType
  label          String
  totalChunks    Int             @default(0)
  embeddedChunks Int             @default(0)
  failedChunks   Int             @default(0)
  status         MossIndexStatus @default(QUEUED)
  items          MossIndexItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([protocolId, runId, assetType])
  @@index([status])
  @@map("moss_index_assets")
}

model MossIndexItem {
  id                String           @id @default(cuid())
  assetId           String?
  asset             MossIndexAsset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  protocolId        String?
  protocol          Protocol?        @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  runId             String?
  run               ProcessingRun?   @relation(fields: [runId], references: [id], onDelete: SetNull)
  assetType         MossAssetType
  objectType        String
  objectId          String
  protocolChunkId   String?
  protocolChunk     ProtocolChunk?   @relation(fields: [protocolChunkId], references: [id], onDelete: SetNull)
  evidenceSnippetId String?
  evidenceSnippet   EvidenceSnippet? @relation(fields: [evidenceSnippetId], references: [id], onDelete: SetNull)
  citationId        String?
  citation          Citation?        @relation(fields: [citationId], references: [id], onDelete: SetNull)
  mossDocumentId    String?
  namespace         String?
  status            MossIndexStatus  @default(QUEUED)
  failureReason     String?
  metadata          Json?
  embeddedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([assetId])
  @@index([protocolId])
  @@index([objectType, objectId])
  @@index([status])
  @@map("moss_index_items")
}

model MslBrief {
  id                 String                   @id @default(cuid())
  protocolId         String
  protocol           Protocol                 @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  runId              String?
  run                ProcessingRun?           @relation(fields: [runId], references: [id], onDelete: SetNull)
  candidateId        String?
  candidate          ProtocolExpertCandidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  expertId           String?
  expert             Expert?                  @relation(fields: [expertId], references: [id], onDelete: SetNull)
  createdById        String?
  createdBy          User?                    @relation("MslBriefCreator", fields: [createdById], references: [id], onDelete: SetNull)
  status             BriefStatus              @default(DRAFT)
  title              String
  summary            String?
  complianceWarning  String?
  generatedAt        DateTime?
  reviewedAt         DateTime?
  sections           MslBriefSection[]
  suggestedQuestions SuggestedQuestion[]
  citations          BriefCitation[]
  complianceChecks   ComplianceCheck[]
  complianceFlags    ComplianceFlag[]
  exports            ExportArtifact[]
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  @@index([protocolId])
  @@index([candidateId])
  @@index([expertId])
  @@map("msl_briefs")
}

model MslBriefSection {
  id         String          @id @default(cuid())
  briefId    String
  brief      MslBrief        @relation(fields: [briefId], references: [id], onDelete: Cascade)
  sectionKey String
  heading    String
  content    String
  order      Int
  citations  BriefCitation[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([briefId, sectionKey])
  @@map("msl_brief_sections")
}

model SuggestedQuestion {
  id         String   @id @default(cuid())
  briefId    String
  brief      MslBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  question   String
  rationale  String?
  order      Int
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([briefId])
  @@map("suggested_questions")
}

model BriefCitation {
  id             String           @id @default(cuid())
  briefId        String
  brief          MslBrief         @relation(fields: [briefId], references: [id], onDelete: Cascade)
  briefSectionId String?
  briefSection   MslBriefSection? @relation(fields: [briefSectionId], references: [id], onDelete: Cascade)
  citationId     String
  citation       Citation         @relation(fields: [citationId], references: [id], onDelete: Cascade)
  claimText      String?
  createdAt      DateTime         @default(now())

  @@unique([briefId, citationId, claimText])
  @@index([briefSectionId])
  @@index([citationId])
  @@map("brief_citations")
}

model ProtocolBriefCitation {
  id             String               @id @default(cuid())
  briefSectionId String
  briefSection   ProtocolBriefSection @relation(fields: [briefSectionId], references: [id], onDelete: Cascade)
  citationId     String
  citation       Citation             @relation(fields: [citationId], references: [id], onDelete: Cascade)
  claimText      String?
  createdAt      DateTime             @default(now())

  @@unique([briefSectionId, citationId])
  @@index([citationId])
  @@map("protocol_brief_citations")
}

model ConversationSession {
  id              String                @id @default(cuid())
  protocolId      String?
  protocol        Protocol?             @relation(fields: [protocolId], references: [id], onDelete: SetNull)
  userId          String?
  user            User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel         ConversationChannel   @default(VOICE)
  liveKitRoomName String?
  liveKitUserId   String?
  metadata        Json?
  messages        ConversationMessage[]
  startedAt       DateTime              @default(now())
  endedAt         DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([protocolId])
  @@index([userId])
  @@map("conversation_sessions")
}

model ConversationMessage {
  id               String                        @id @default(cuid())
  sessionId        String
  session          ConversationSession           @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role             MessageRole
  content          String
  transcriptText   String?
  toolName         String?
  audioSeconds     Float?
  metadata         Json?
  citations        ConversationMessageCitation[]
  complianceChecks ComplianceCheck[]
  createdAt        DateTime                      @default(now())

  @@index([sessionId])
  @@index([role])
  @@map("conversation_messages")
}

model ConversationMessageCitation {
  id         String              @id @default(cuid())
  messageId  String
  message    ConversationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  citationId String
  citation   Citation            @relation(fields: [citationId], references: [id], onDelete: Cascade)
  claimText  String?
  createdAt  DateTime            @default(now())

  @@unique([messageId, citationId])
  @@index([citationId])
  @@map("conversation_message_citations")
}

model ExportArtifact {
  id          String         @id @default(cuid())
  protocolId  String
  protocol    Protocol       @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  runId       String?
  run         ProcessingRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  briefId     String?
  brief       MslBrief?      @relation(fields: [briefId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?          @relation("ExportArtifactCreator", fields: [createdById], references: [id], onDelete: SetNull)
  format      ExportFormat
  label       String
  description String?
  storageUrl  String?
  status      ExportStatus   @default(QUEUED)
  expiresAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([protocolId])
  @@index([runId])
  @@index([briefId])
  @@map("export_artifacts")
}

model AuditEvent {
  id             String         @id @default(cuid())
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  userId         String?
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  protocolId     String?
  protocol       Protocol?      @relation(fields: [protocolId], references: [id], onDelete: SetNull)
  runId          String?
  run            ProcessingRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  action         String
  entityType     String
  entityId       String?
  payload        Json?
  createdAt      DateTime       @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([protocolId])
  @@index([entityType, entityId])
  @@map("audit_events")
}
