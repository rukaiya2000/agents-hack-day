# LiveKit — voice transport + inference (STT/LLM/TTS). Written by `lk app env -w agent-py`.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Moss — semantic retrieval (knowledge) + per-user memory (https://docs.moss.dev/docs)
MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=knowledge
MOSS_MEMORY_INDEX_NAME=memory
MOSS_MODEL_ID=moss-minilm

# Bright Data — live web search for product listings/prices
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_SERP_ZONE=
BRIGHT_DATA_UNLOCKER_ZONE=
BRIGHT_DATA_COUNTRY=us

# OpenAI — optional; only needed if you enable the hosted web-search research path.
OPENAI_API_KEY=

# Voice latency controls. Defaults are tuned for a fast English demo.
LIVEKIT_LLM_MODEL=openai/gpt-4.1-mini
LIVEKIT_STT_MODEL=deepgram/nova-3
LIVEKIT_STT_LANGUAGE=en
LIVEKIT_TTS_MODEL=cartesia/sonic-3
LIVEKIT_TTS_VOICE=9626c31c-bec5-4cca-baa8-f8ba9e84c8bc
VOICE_TURN_DETECTION_MODE=vad
VOICE_ENDPOINTING_MODE=fixed
VOICE_MIN_ENDPOINTING_DELAY=0.2
VOICE_MAX_ENDPOINTING_DELAY=1.2
VOICE_ALLOW_INTERRUPTIONS=1
VOICE_INTERRUPTION_MODE=vad
VOICE_MIN_INTERRUPTION_DURATION=0.25
VOICE_MIN_INTERRUPTION_WORDS=0
VOICE_PREEMPTIVE_GENERATION=1
VOICE_PREEMPTIVE_TTS=1
VOICE_PREEMPTIVE_MAX_SPEECH_DURATION=6
VOICE_AUDIO_ENHANCEMENT=0
